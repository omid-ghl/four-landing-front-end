{
    "name": "four-landing-front-end",
    "type": "module",
    "version": "57",
    "scripts": {
        "dev": "astro dev --port 3000",
        "dev:host": "astro dev --host --port 3000",
        "build": "astro build",
        "build:staging": "astro check && astro build --mode staging",
        "start": "pm2 start --name four.io dist/server/entry.mjs",
        "restart": "pm2 restart four.io",
        "logs": "pm2 logs four.io",
        "astro": "astro",
        "format": "prettier --write . --config .prettierrc --ignore-path .prettierignore --cache",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "prepare": "husky",
        "incrementVersion": "node script/incrementVersion.cjs"
    },
    "dependencies": {
        "@astrojs/check": "^0.9.2",
        "@astrojs/netlify": "^5.5.4",
        "@astrojs/node": "^8.3.2",
        "@astrojs/react": "^3.6.1",
        "@astrojs/sitemap": "^3.1.6",
        "@astrojs/tailwind": "^5.1.0",
        "@playform/compress": "^0.1.1",
        "@radix-ui/react-accordion": "^1.2.1",
        "@radix-ui/react-icons": "^1.3.0",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "astro": "^4.13.1",
        "axios": "^1.7.4",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "i18next": "^23.12.2",
        "lucide-react": "^0.453.0",
        "pm2": "^5.4.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-google-recaptcha-v3": "^1.10.1",
        "react-hot-toast": "^2.4.1",
        "remove": "^0.1.5",
        "sanitize-html": "^2.13.0",
        "tailwind-merge": "^2.5.4",
        "tailwindcss": "^3.4.8",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^5.5.4"
    },
    "devDependencies": {
        "@eslint/js": "^9.8.0",
        "@types/sanitize-html": "^2.11.0",
        "eslint": "^9.8.0",
        "globals": "^15.9.0",
        "husky": "^9.1.4",
        "prettier": "3.3.3",
        "typescript-eslint": "^8.0.1"
    }
}
